<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd"><key id="d4" for="edge" attr.name="description" attr.type="string"/>
<key id="d3" for="edge" attr.name="weight" attr.type="double"/>
<key id="d2" for="edge" attr.name="relation" attr.type="string"/>
<key id="d1" for="node" attr.name="definition" attr.type="string"/>
<key id="d0" for="node" attr.name="category" attr.type="string"/>
<graph edgedefault="directed"><node id="编码">
  <data key="d0"></data>
  <data key="d1">把信息转换成可供传输的信号，如把一份电文变为一串嘀嘀嗒嗒的摩尔斯电码</data>
</node>
<node id="相容性">
  <data key="d0"></data>
  <data key="d1">新旧事物的相容程度，或者说某一新事物与对应的旧事物之间相比存在的差异</data>
</node>
<node id="复杂性">
  <data key="d0"></data>
  <data key="d1">新事物被理解被运用的相对难度，难度越小，人们对新事物的肯定倾向就越强烈</data>
</node>
<node id="装车过程">
  <data key="d0"></data>
  <data key="d1">把信息加载到符号上面，而符号就等同于传播信息的运输工具</data>
</node>
<node id="类似与相近">
  <data key="d0">concept</data>
  <data key="d1">类似与相近是说，人们在感知事物时往往趋向于把相似的东西视为一类，本能地喜欢合并同类项</data>
</node>
<node id="完形趋向">
  <data key="d0">concept</data>
  <data key="d1">完形趋向是指人们对事物的感知总是趋向于整齐划一，而力求避免残缺凌乱</data>
</node>
<node id="残缺闭合">
  <data key="d0">concept</data>
  <data key="d1">残缺闭合与上述完形趋向有共同或相通之处</data>
</node>
<node id="共同命运">
  <data key="d0">concept</data>
  <data key="d1">共同命运其实同第一点的类似与相近一样，也是指人们倾向于把类似的东西当成一个共同体来感知</data>
</node>
<edge source="复杂性" target="相容性">
  <data key="d2">related_to</data>
  <data key="d3">1.0</data>
  <data key="d4">'相容性' mentioned in definition of '复杂性'</data>
</edge>
<edge source="残缺闭合" target="完形趋向">
  <data key="d2">related_to</data>
  <data key="d3">1.0</data>
  <data key="d4">'完形趋向' mentioned in definition of '残缺闭合'</data>
</edge>
<edge source="共同命运" target="类似与相近">
  <data key="d2">related_to</data>
  <data key="d3">1.0</data>
  <data key="d4">'类似与相近' mentioned in definition of '共同命运'</data>
</edge>
</graph></graphml>